# ============================================================
# FinancePro — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA envie o arquivo .env para o repositório Git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: https://app.supabase.com > Seu projeto > Settings > API

# URL do projeto Supabase (ex: https://abcxyz.supabase.co)
VITE_SUPABASE_URL=

# Chave pública anon (segura para expor no frontend)
VITE_SUPABASE_ANON_KEY=

# ── Configuração no Netlify ───────────────────────────────────
# Em produção, defina estas variáveis em:
# Netlify > Site configuration > Environment variables
# NÃO coloque a service_role key aqui — ela é secret e só vai
# em variáveis do servidor (Edge Functions / Supabase secrets).
